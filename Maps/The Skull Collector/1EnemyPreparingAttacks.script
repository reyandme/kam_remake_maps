procedure PreparingEnemyAttacks(i, j: Integer); //i = player no.-1, j = variation; variation 1 = melee etc, variation 2 = mounted
begin	
	if (i = 2) then
		begin
			A.AIAttackRemoveAll(2);
			case U.RandomRangeI(0, 1) of
				0: begin
						A.AIStartPosition(PlayerNumber[2],76,82); 
					end;
				1: begin
						A.AIStartPosition(PlayerNumber[2],53,94);
					end;
			end;
			if (j = 1) then				
				begin
					A.AIDefencePositionAdd (PlayerNumber[2], 36, 62, 2, 3, 20, 0); //add attack variation 1
					A.AIDefencePositionAdd (PlayerNumber[2], 32, 60, 2, 3, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 32, 65, 2, 3, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 28, 62, 2, 3, 20, 0);
					
					A.AIDefencePositionAdd (PlayerNumber[2], 21, 48, 4, 0, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 27, 48, 4, 0, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 21, 44, 4, 0, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 27, 44, 4, 0, 20, 0);
					
					A.AIDefencePositionAdd (PlayerNumber[2], 27, 52, 4, 1, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 24, 36, 4, 1, 20, 0);
					
					A.AIDefencePositionAdd (PlayerNumber[2], 21, 41, 4, 2, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 26, 41, 4, 2, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 21, 39, 4, 2, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 26, 39, 4, 2, 20, 0);
				end else
			if (j = 2) then
				begin
					A.AIDefencePositionAdd (PlayerNumber[2], 36, 62, 2, 3, 20, 0); //add attack variation 2
					A.AIDefencePositionAdd (PlayerNumber[2], 32, 60, 2, 3, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 32, 65, 2, 3, 20, 0);
					A.AIDefencePositionAdd (PlayerNumber[2], 28, 62, 2, 3, 20, 0);
				end;	
